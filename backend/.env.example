# 数据库配置
# 本地开发默认不需要配置，会自动降级为本地 SQLite (knowledge_passbook.db)
# 生产环境上线时，请将此文件复制为 .env，并修改下方的 PostgreSQL 连接地址

# 1. 生产环境 MySQL 数据库连接串 (加上 ?charset=utf8mb4 以完美支持中文字符与 emoji 表情)
# 格式: mysql+pymysql://[用户名]:[密码]@[主机地址]:[端口号]/[数据库名]?charset=utf8mb4
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/knowledge_passbook?charset=utf8mb4

# 2. 生产环境 PostgreSQL 数据库连接串 (备选)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/knowledge_passbook
